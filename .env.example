# --- OpenAI (powers the Ask-Saket chatbot) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# --- Lead notifications via Resend (optional) ---
# If RESEND_API_KEY is empty, captured leads are still saved to leads.json
# and printed to the server log instead of emailed.
RESEND_API_KEY=
RESEND_FROM=Saket Portfolio <onboarding@resend.dev>
LEAD_TO_EMAIL=saketmundhada7@gmail.com

# --- Admin (view captured leads) ---
# GET /api/admin/leads with header  x-admin-secret: <this value>
ADMIN_SECRET=change-me

# --- Server ---
PORT=4000
# Optional: absolute path for leads.json on a Railway persistent volume.
LEADS_PATH=

# --- Public chat rate limit (per IP) ---
CHAT_RATE_WINDOW_MS=60000
CHAT_RATE_MAX=12
